<tr>
<th class=3D"confluenceTh">
<p>Property</p></th>
<th class=3D"confluenceTh">
<p>Description</p></th>
<th class=3D"confluenceTh">
<p>Formula</p></th>
</tr>
<tr>
<td class=3D"confluenceTd">
<p><strong>Wavelength (=CE=BB)</strong></p></td>
<td class=3D"confluenceTd">
<p>Distance between two crests or compressions</p></td>
<td class=3D"confluenceTd">
<p>meter (m)</p></td>
</tr>
<tr>
<td class=3D"confluenceTd">
