<td class=3D"confluenceTd">
<p>&gt; 1 m</p></td>
<td class=3D"confluenceTd">
<p>Broadcasting</p></td>
</tr>
<tr>
<td class=3D"confluenceTd">
<p>Microwaves</p></td>
<td class=3D"confluenceTd">
<p>1 m =E2=80=93 1 mm</p></td>
<td class=3D"confluenceTd">
<p>Ovens, radar</p></td>
</tr>
<tr>
