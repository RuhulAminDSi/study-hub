<td class=3D"confluenceTd">
<p><code>malloc()</code>, <code>free()</code>, <code>atoi()</code>, <code>e=
xit()</code></p></td>
</tr>
<tr>
<td class=3D"confluenceTd">
<p><code>&lt;ctype.h&gt;</code></p></td>
<td class=3D"confluenceTd">
<p>Character handling</p></td>
<td class=3D"confluenceTd">
<p><code>toupper()</code>, <code>tolower()</code>, <code>isalpha()</code></=
p></td>
</tr>
<tr>
<td class=3D"confluenceTd">
<p><code>&lt;time.h&gt;</code></p></td>
<td class=3D"confluenceTd">
<p>Date and time</p></td>
<td class=3D"confluenceTd">
<p><code>time()</code>, <code>clock()</code></p></td>
</tr>
<tr>
<td class=3D"confluenceTd">
<p><code>&lt;stdbool.h&gt;</code></p></td>
<td class=3D"confluenceTd">
<p>Boolean data type</p></td>
<td class=3D"confluenceTd">
<p><code>true</code>, <code>false</code></p></td>
</tr>
<tr>
<td class=3D"confluenceTd">
<p><code>&lt;limits.h&gt;</code></p></td>
<td class=3D"confluenceTd">
<p>Integer limits</p></td>
<td class=3D"confluenceTd">
<p><code>INT_MAX</code>, <code>INT_MIN</code></p></td>
</tr>
<tr>
<td class=3D"confluenceTd">
<p><code>&lt;float.h&gt;</code></p></td>
<td class=3D"confluenceTd">
<p>Floating-point limits</p></td>
<td class=3D"confluenceTd">
<p><code>FLT_MAX</code>, <code>FLT_MIN</code></p></td>
</tr>
