</tr>
<tr>
<td class=3D"confluenceTd">
<p>Approach</p></td>
<td class=3D"confluenceTd">
<p>Linear</p></td>
<td class=3D"confluenceTd">
<p>Iterative &amp; exploratory</p></td>
</tr>
</tbody>
</table>
</div>
